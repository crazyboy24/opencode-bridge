# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Force these to always be LF
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Dockerfile  text eol=lf
LICENSE     text eol=lf
.env*       text eol=lf

# Binaries — don't touch
*.png       binary
*.jpg       binary
*.ico       binary
