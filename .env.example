# ── Required ──────────────────────────────────────────────────────────────────

# URL of your running OpenCode server
OPENCODE_URL=http://localhost:4096

# ── OpenCode auth (if OPENCODE_SERVER_PASSWORD is set on OpenCode) ────────────
OPENCODE_SERVER_PASSWORD=

# ── Provider ──────────────────────────────────────────────────────────────────

# Default provider — can be overridden per-request via "provider/model" format
# Common values: github-copilot | anthropic | openai | openrouter
OPENCODE_PROVIDER_ID=github-copilot

# Fallback model when client doesn't specify one
DEFAULT_MODEL=gpt-4o

# ── Bridge auth ───────────────────────────────────────────────────────────────

# Require Bearer token on all /v1/* endpoints. Leave empty to disable.
OPENCODE_PROXY_API_KEY=

# ── Network ───────────────────────────────────────────────────────────────────

PORT=5000

# ── Timeouts & retries ────────────────────────────────────────────────────────

# Max time to wait for OpenCode to respond (ms). 10min default suits o3/heavy tasks.
TIMEOUT_MS=600000

# SSE keep-alive ping interval (ms). Prevents connection drops on slow responses.
HEARTBEAT_MS=15000

# Number of retries on transient OpenCode errors (not timeouts or 4xx)
RETRY_COUNT=2
RETRY_DELAY_MS=2000

# ── Session cleanup ───────────────────────────────────────────────────────────

# Delete bridge-created sessions older than this many hours
SESSION_TTL_HOURS=2

# How often to run cleanup (ms). Default: every hour.
CLEANUP_INTERVAL_MS=3600000

# ── Logging ───────────────────────────────────────────────────────────────────

# silent | info | debug
LOG_LEVEL=info

# Optional log file path (in addition to stdout). Mount /data in Docker to persist.
# LOG_FILE=/data/logs/bridge.log
